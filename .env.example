# RevenueCat — paste your project's iOS + Android public keys.
# Find these at https://app.revenuecat.com → your project → API keys.
# Leave empty to run the app in mock-mode (purchases short-circuit, useProMock
# drives Pro state; useful for UI dev without a configured RC account).
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Google Places — used by AddPlaceSheet's address autocomplete (Plan 5).
# Create the key at https://console.cloud.google.com/apis/credentials and
# restrict it to the iOS + Android bundle id `com.timemapper.app`.
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Sentry — optional. When set AND `@sentry/react-native` is installed the app
# reports crashes + boot failures. Leave empty to disable (the app logs a
# single info line at boot confirming crash reporting is off).
#
# To enable:
#   1. npm install @sentry/react-native
#   2. Create a project at sentry.io, copy the DSN
#   3. Paste it here and rebuild
EXPO_PUBLIC_SENTRY_DSN=
