{
  "cli": { "version": ">= 10.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_REVENUECAT_IOS_KEY": "",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": "",
        "EXPO_PUBLIC_SENTRY_DSN": ""
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_REVENUECAT_IOS_KEY": "",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": "",
        "EXPO_PUBLIC_SENTRY_DSN": ""
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_REVENUECAT_IOS_KEY": "",
        "EXPO_PUBLIC_REVENUECAT_ANDROID_KEY": "",
        "EXPO_PUBLIC_SENTRY_DSN": ""
      }
    }
  },
  "_submitNotes": [
    "Before running `eas submit --profile production`:",
    "  1. iOS — replace `appleId`, `ascAppId`, `appleTeamId` below with your real values.",
    "     Find ascAppId in App Store Connect → My Apps → your app → App Information → Apple ID.",
    "  2. Android — put your Play Console service-account JSON at `play-service-account.json`",
    "     (or adjust `serviceAccountKeyPath`). See https://docs.expo.dev/submit/android/",
    "  3. Store metadata lives under `store/ios/` + `store/android/` — fill before submitting."
  ],
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID_EMAIL",
        "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal"
      }
    }
  }
}
