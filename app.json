{
  "expo": {
    "name": "Time Mapper",
    "slug": "time-mapper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "timemapper",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.timemapper.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "UIBackgroundModes": ["location", "fetch", "processing"],
        "BGTaskSchedulerPermittedIdentifiers": ["com.timemapper.app.geofence"],
        "NSLocationWhenInUseUsageDescription": "Time Mapper uses your location to detect when you arrive at a place you've saved — so it can start the timer automatically. Your location stays on your device.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Time Mapper uses Always location so it can start and stop timers automatically when you enter or leave your saved places — even with the app closed. Your location never leaves your device.",
        "NSLocationAlwaysUsageDescription": "Time Mapper uses Always location so it can start and stop timers automatically when you enter or leave your saved places — even with the app closed. Your location never leaves your device.",
        "NSUserNotificationsUsageDescription": "Time Mapper sends a short confirmation when it starts or stops a timer automatically.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.timemapper.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "com.android.vending.BILLING"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Time Mapper uses Always location so it can start and stop timers automatically when you enter or leave your saved places — even with the app closed. Your location never leaves your device.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF7A1A"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "minSdkVersion": 24
          }
        }
      ],
      "expo-sqlite",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "revenueCatIosKey": "${EXPO_PUBLIC_REVENUECAT_IOS_KEY}",
      "revenueCatAndroidKey": "${EXPO_PUBLIC_REVENUECAT_ANDROID_KEY}",
      "sentryDsn": "${EXPO_PUBLIC_SENTRY_DSN}"
    }
  }
}
